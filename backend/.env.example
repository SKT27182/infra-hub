# =============================================================================
# Infra Hub - Environment Configuration
# =============================================================================
# Copy this file to .env and update with secure passwords
# DO NOT commit .env to version control!

API_PORT=8888
SERVICE_PUBLIC_HOST=127.0.0.1
ADMIN_EMAIL=admin@infra.local
ADMIN_PASSWORD=change-this-default-admin-password
CORS_ORIGINS=https://infra.skt27182.com

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=infra

# =============================================================================
# pgAdmin
# =============================================================================
PGADMIN_EMAIL=admin@infra.local
PGADMIN_PASSWORD=your-secure-password
PGADMIN_PORT=5050

# =============================================================================
# Redis
# =============================================================================
REDIS_PASSWORD=your-secure-password
REDISINSIGHT_PORT=5540

# =============================================================================
# MongoDB
# =============================================================================
MONGO_USER=admin
MONGO_PASSWORD=your-secure-password

# =============================================================================
# Mongo Express (Web UI)
# =============================================================================
ME_USER=admin
ME_PASSWORD=your-secure-password
MONGO_EXPRESS_PORT=8081

# =============================================================================
# Qdrant (Optional API Key - leave empty for no auth)
# =============================================================================
QDRANT_API_KEY=
QDRANT_REST_PORT=6333

# =============================================================================
# MinIO (Password must be at least 8 characters)
# =============================================================================
MINIO_USER=admin
MINIO_PASSWORD=your-secure-password-8chars
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
